    "@sentry/nextjs": "^10.43.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tavily/core": "^0.7.2",
    "ai": "^6.0.103",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
