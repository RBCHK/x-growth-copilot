// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations          Conversation[]
  voiceBankEntries       VoiceBankEntry[]
  scheduledSlots         ScheduledSlot[]
  strategyConfigs        StrategyConfig[]
  xPosts                 XPost[]
  dailyAccountStats      DailyAccountStats[]
  strategyAnalyses       StrategyAnalysis[]
  researchNotes          ResearchNote[]
  dailyInsights          DailyInsight[]
  followersSnapshots     FollowersSnapshot[]
  postEngagementSnapshots PostEngagementSnapshot[]
  planProposals          PlanProposal[]
  xApiCallLogs           XApiCallLog[]
  xApiToken              XApiToken?
}

model XApiToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  xUserId      String
  xUsername     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([xUserId])
}

// ─── Enums ───────────────────────────────────────────────

enum ContentType {
  REPLY
  POST
  THREAD
  ARTICLE
}

enum ConversationStatus {
  DRAFT
  SCHEDULED
  POSTED
}

enum SlotType {
  POST
  REPLY
  THREAD
  ARTICLE
}

enum SlotStatus {
  EMPTY
  FILLED
  POSTED
}

enum VoiceBankType {
  REPLY
  POST
}

enum XPostType {
  POST
  REPLY
}

enum DataSource {
  CSV
  API
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum XApiResourceType {
  POST_READ
  USER_READ
  TREND_READ
}

enum CronJobStatus {
  SUCCESS
  PARTIAL
  FAILURE
  SKIPPED
}

// ─── Content ─────────────────────────────────────────────

model Conversation {
  id                String              @id @default(cuid())
  userId            String
  title             String
  contentType       ContentType
  status            ConversationStatus  @default(DRAFT)
  originalPostText  String?
  originalPostUrl   String?
  pinned            Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  lastActivityAt    DateTime            @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  notes    Note[]
  slots    ScheduledSlot[]

  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Note {
  id             String   @id @default(cuid())
  conversationId String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model VoiceBankEntry {
  id        String         @id @default(cuid())
  userId    String
  content   String
  type      VoiceBankType
  topic     String?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Schedule ────────────────────────────────────────────

model ScheduledSlot {
  id             String     @id @default(cuid())
  userId         String
  date           DateTime
  timeSlot       String
  slotType       SlotType
  status         SlotStatus @default(EMPTY)
  content        String?
  conversationId String?
  postedAt       DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model StrategyConfig {
  id                 String    @id @default(cuid())
  userId             String
  postsPerDay        Int       @default(2)
  replySessionsPerDay Int      @default(4)
  timeSlots          Json      // e.g. ["9:00 AM", "12:00 PM", "3:00 PM", "6:00 PM"]
  scheduleConfig     Json?     // { posts: { slots: [...] }, threads: {...}, articles: {...} }
  targetFollowers    Int?      // growth goal, e.g. 10000
  targetDate         DateTime? // goal deadline, e.g. 2026-12-31
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── X Analytics ─────────────────────────────────────────

model XPost {
  id            String     @id @default(cuid())
  userId        String
  postId        String
  date          DateTime
  text          String
  postLink      String?
  postType      XPostType

  // Core metrics (API owns these)
  impressions   Int        @default(0)
  likes         Int        @default(0)
  engagements   Int        @default(0)
  bookmarks     Int        @default(0)
  replies       Int        @default(0)
  reposts       Int        @default(0)
  quoteCount    Int        @default(0)
  urlClicks     Int        @default(0)
  profileVisits Int        @default(0)

  // CSV-only enrichment (API doesn't provide these)
  newFollowers  Int        @default(0)
  detailExpands Int        @default(0)

  // Source tracking
  dataSource    DataSource @default(CSV)
  updatedAt     DateTime   @updatedAt
  createdAt     DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

model DailyAccountStats {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  impressions   Int      @default(0)
  likes         Int      @default(0)
  engagements   Int      @default(0)
  bookmarks     Int      @default(0)
  shares        Int      @default(0)
  newFollows    Int      @default(0)
  unfollows     Int      @default(0)
  replies       Int      @default(0)
  reposts       Int      @default(0)
  profileVisits Int      @default(0)
  createPost    Int      @default(0)
  videoViews    Int      @default(0)
  mediaViews    Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ─── AI Agents ───────────────────────────────────────────

model StrategyAnalysis {
  id             String   @id @default(cuid())
  userId         String
  csvSummary     Json     // { totalPosts, avgImpressions, topPosts[], dateRange }
  searchQueries  String[] // queries the agent ran, for transparency
  recommendation String   // full markdown output from Claude
  weekStart      DateTime // the Monday of the week this analysis covers
  autoGenerated  Boolean  @default(false) // true for cron-generated analyses
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ResearchNote {
  id        String   @id @default(cuid())
  userId    String
  topic     String
  summary   String
  sources   Json     // [{ title, url, snippet }]
  queries   String[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyInsight {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // UTC midnight, one record per day per user
  insights  Json     // string[] of 5 insights in Russian
  context   Json     // { strategyAnalysisId, researchNoteIds[], daysOfStats }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model FollowersSnapshot {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime // UTC midnight, one per day per user
  followersCount  Int
  followingCount  Int
  deltaFollowers  Int      @default(0) // today - yesterday
  deltaFollowing  Int      @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ─── Trends (global, not per-user) ──────────────────────

model TrendSnapshot {
  id             String    @id @default(cuid())
  date           DateTime  // UTC midnight of the day fetched
  trendName      String
  postCount      Int       @default(0)
  category       String?
  trendingSince  DateTime?
  createdAt      DateTime  @default(now())

  fetchHour     Int       @default(0) // UTC hour of fetch (0-23), enables multiple snapshots per day

  @@index([date, fetchHour])
}

// ─── Engagement Tracking ─────────────────────────────────

model PostEngagementSnapshot {
  id            String   @id @default(cuid())
  userId        String
  postId        String
  snapshotDate  DateTime
  impressions   Int      @default(0)
  likes         Int      @default(0)
  engagements   Int      @default(0)
  bookmarks     Int      @default(0)
  replies       Int      @default(0)
  reposts       Int      @default(0)
  quoteCount    Int      @default(0)
  profileVisits Int      @default(0)
  urlClicks     Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, snapshotDate])
  @@index([userId])
  @@index([postId])
}

// ─── Plan Proposals ──────────────────────────────────────

model PlanProposal {
  id              String         @id @default(cuid())
  userId          String
  status          ProposalStatus @default(PENDING)
  proposalType    String         @default("config") // "config" | "schedule" (legacy)
  changes         Json           // ConfigChange[] or PlanChange[] depending on proposalType
  summary         String         // markdown summary from strategist
  analysisId      String?        // link to StrategyAnalysis that generated it
  metricsSnapshot Json?          // MetricsSnapshot at time of proposal creation
  createdAt       DateTime       @default(now())
  reviewedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Admin: API Cost Tracking ───────────────────────────

model XApiCallLog {
  id            String           @id @default(cuid())
  endpoint      String           // e.g. "/users/me", "/users/:id/tweets"
  resourceType  XApiResourceType
  resourceCount Int              // number of resources fetched
  costCents     Float            // calculated cost in cents
  callerJob     String?          // cron job name or "manual"
  userId        String?          // user for whom the call was made (null for global, e.g. trends)
  httpStatus    Int?
  error         String?          // truncated to 2000 chars
  calledAt      DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([calledAt])
  @@index([userId])
}

// ─── Admin: Cron Job Run History ────────────────────────

model CronJobRun {
  id         String        @id @default(cuid())
  jobName    String
  status     CronJobStatus
  durationMs Int?
  resultJson Json?
  error      String?       // truncated to 2000 chars
  startedAt  DateTime      @default(now())

  @@index([jobName])
  @@index([startedAt])
}

// ─── Admin: Cron Job Config (toggle on/off) ─────────────

model CronJobConfig {
  jobName     String   @id
  enabled     Boolean  @default(true)
  description String?
  schedule    String?  // human-readable cron expression
  updatedBy   String?  // clerkId of admin who last toggled
  updatedAt   DateTime @updatedAt
}
