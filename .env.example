X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# X (Twitter) API — OAuth 2.0
X_OAUTH2_ACCESS_TOKEN=

# Sentry (error monitoring) — NEXT_PUBLIC_ prefix exposes to client
NEXT_PUBLIC_SENTRY_DSN=
