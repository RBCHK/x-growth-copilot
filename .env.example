# Database (Prisma + Supabase)
# Runtime queries (Prisma Client via driver adapter) — transaction-mode pooler, port 6543
DATABASE_URL=
# Migrations (prisma migrate deploy) — session-mode pooler, port 5432
DIRECT_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Vercel Cron
CRON_SECRET=

# Anthropic (AI SDK) — read automatically by @ai-sdk/anthropic
ANTHROPIC_API_KEY=

# Tavily (web search)
TAVILY_API_KEY=

# X (Twitter) API — OAuth 2.0 PKCE (app-level credentials from Developer Portal)
X_CLIENT_ID=
X_CLIENT_SECRET=

# Token encryption key for X API tokens in DB (generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# App URL (used for OAuth callback redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (error monitoring) — NEXT_PUBLIC_ prefix exposes to client
NEXT_PUBLIC_SENTRY_DSN=
